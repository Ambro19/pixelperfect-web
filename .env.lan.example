# ====================================
# PIXELPERFECT FRONTEND - LAN DEV (TEMPLATE)
# File: frontend/.env.lan.example
# Author: OneTechly
# Updated: March 2026
#
# USE: Copy to .env.lan then run: npm run start:lan
#
# When your LAN IP changes (router DHCP reassignment):
#   1. Update REACT_APP_API_URL below to your new IP
#   2. Update CORS_DEV_ORIGINS in backend/.env to match
#   3. Restart both frontend and backend
#
# Find your current IP:
#   Windows: ipconfig | findstr "IPv4"
#   Mac/Linux: ipconfig getifaddr en0
# ====================================

# ✅ Updated to current LAN IP (Mar 2026)
REACT_APP_API_URL=http://192.168.1.158:8000
REACT_APP_API_BASE_URL=http://192.168.1.158:8000

REACT_APP_DEBUG=true
REACT_APP_VERBOSE_API_LOGS=true

# Optional: longer timeout on LAN (mobile can be slower)
# REACT_APP_API_TIMEOUT=45000
